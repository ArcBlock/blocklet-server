SKIP_PREFLIGHT_CHECK=true
GENERATE_SOURCEMAP=false

ABT_NODE_UPDATER_PORT=40405
ABT_NODE_SERVICE_PORT=40406
ABT_NODE_EVENT_PORT=40407
ABT_NODE_EVENT_HTTP_PORT=40411

# server only
ABT_NODE_SESSION_TTL="1d"
ABT_NODE_MODE="production"

# both server and client
ABT_NODE_ADMIN_PATH="/admin"

ABT_NODE_PACKAGE_NAME = "@blocklet/cli"

ABT_NODE_SERVICE_FE_PORT="3040"

# disable mfa protected methods totally
# VITE_NO_MFA_PROTECTED_METHODS=1

# disable cluster mode for blocklet service
SKIP_DEV_CLUSTER=1

# 使用的 postgres 版本
ABT_NODE_POSTGRES_VERSION=17.5
