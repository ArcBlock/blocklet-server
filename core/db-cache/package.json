{
  "name": "@abtnode/db-cache",
  "version": "1.17.12",
  "description": "Db cache use redis, sqlite or memory as backend",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "ts-check": "npx tsc --noemit --skipLibCheck --incremental --tsBuildInfoFile './node_modules/.tsbuildinfo'",
    "lint": "npm run ts-check && eslint src",
    "lint:fix": "npm run lint -- --fix",
    "build": "unbuild",
    "build:db-cache": "unbuild && npm run build"
  },
  "keywords": [],
  "author": {
    "name": "ArcBlock",
    "email": "blocklet@arcblock.io",
    "url": "https://github.com/ArcBlock"
  },
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArcBlock/blocklet-server.git",
    "directory": "core/db-cache"
  },
  "bugs": {
    "url": "https://github.com/ArcBlock/blocklet-server/issues"
  },
  "homepage": "https://github.com/ArcBlock/blocklet-server/tree/main/core/db-cache#readme",
  "dependencies": {
    "@arcblock/event-hub": "1.29.27",
    "@types/proper-lockfile": "^4.1.4",
    "lru-cache": "^11.1.0",
    "proper-lockfile": "^4.1.2",
    "redis": "^5.1.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@arcblock/eslint-config-ts": "^0.3.3",
    "@types/node": "^22.7.5",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "@typescript/native-preview": "^7.0.0-dev.20251230.1",
    "eslint": "^8.57.0",
    "prettier": "^3.3.2",
    "unbuild": "^2.0.0"
  }
}
