    "lint:fix": "npm run lint -- --fix",
    "clean": "rm -fr lib",
    "prebuild": "npm run clean && npm run types",
    "types": "rm -rf ./src/types && node tools/version.js && ts-node tools/types.js && rm -f ./src/types/index.ts && prettier --write ./src/types/notification.ts",
