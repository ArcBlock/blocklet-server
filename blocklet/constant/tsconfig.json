{
  "extends": "../../tsconfig.json",
  "include": [
    "lib",
  ],
  "exclude": [
    "node_modules"
  ],
  "compilerOptions": {
    "alwaysStrict": false,
    "strict": false,
    // https://stackoverflow.com/questions/58172911/typescript-compiler-options-trying-to-get-flat-output-to-outdir
    // https://stackoverflow.com/questions/63552953/tsc-keeps-creating-subfolders-in-the-outdir
    "rootDir": ".",
    "outDir": ".",
    // Override types to exclude bun-types which causes dts-bundle-generator issues
    "types": ["node"]
  }
}