{
  "name": "nft-maker",
  "version": "0.7.4",
  "title": "NFT Maker",
  "description": "Easily “Make” your own NFTs",
  "keywords": [
    "blocklet",
    "react"
  ],
  "group": "dapp",
  "did": "z8ia2birZzhjbXqKnxPUUivmqErdsf3724tr6",
  "main": "blocklet.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blocklet/nft-maker.git",
    "parsedUrl": "https://github.com/blocklet/nft-maker"
  },
  "specVersion": "1.2.8",
  "logo": "logo.png",
  "files": [
    "dist",
    "logo.png",
    "migration/*.js",
    "README.md",
    "blocklet.md",
    "screenshots",
    "api/hooks/pre-start.js",
    "uploads"
  ],
  "interfaces": [
    {
      "type": "web",
      "name": "publicUrl",
      "path": "/",
      "prefix": "*",
      "port": "BLOCKLET_PORT",
      "protocol": "tcp",
      "services": [
        {
          "name": "auth",
          "config": {
            "blockUnauthenticated": false,
            "ignoreUrls": [
              "/nft",
              "/factory",
              "/",
              "/uploads/**",
              "/api/**",
              "/manifest.json",
              "/mint/**",
              "/mint",
              "/blender/api/**",
              "/store/api/**"
            ],
            "whoCanAccess": "invited",
            "profileFields": [
              "fullName",
              "email",
              "avatar"
            ],
            "allowSwitchProfile": true,
            "blockUnauthorized": false
          }
        }
      ],
      "proxyBehavior": "service"
    }
  ],
  "community": "https://community.arcblock.io",
  "documentation": "https://developer.blocklet.io",
  "homepage": "https://store.blocklet.dev",
  "license": "",
  "timeout": {
    "start": 60
  },
  "requirements": {
    "server": ">=1.16.0",
    "os": "*",
    "cpu": "*"
  },
  "scripts": {
    "preStart": "node api/hooks/pre-start.js",
    "dev": "npm run start"
  },
  "environments": [
    {
      "name": "CHAIN_HOST",
      "description": "What's endpoint of the chain?",
      "required": true,
      "default": "https://main.abtnetwork.io/api/",
      "secure": false,
      "shared": true
    },
    {
      "name": "LOCAL_TOKEN_ADDRESS",
      "description": "What's the default token address of the chain?",
      "required": true,
      "default": "z35nNRvYxBoHitx9yZ5ATS88psfShzPPBLxYD",
      "secure": false,
      "shared": true
    },
    {
      "name": "TEMPLATE_OR_FACTORY_MAX_MINT_COUNT",
      "description": "What's maximum number of minted a template or a factory?",
      "required": true,
      "default": "1000000",
      "secure": false,
      "shared": true
    }
  ],
  "capabilities": {
    "clusterMode": false,
    "component": true,
    "navigation": true,
    "didSpace": "required",
    "serverless": true
  },
  "screenshots": [
    "QmPSM67JzdSk83YYX4YDfzsMkFZUrHPbBEj1swLeSiFNwR.png",
    "QmXpe5E97jJUTKG2WxnZzAwss1ecVbugKyypxNMVrP55qw.png",
    "QmVKNMRDR6csA4QynMtjkDt1M3b5aScxdMbJereThF131S.png"
  ],
  "navigation": [
    {
      "id": "makerHeader",
      "title": {
        "en": "NFT Maker",
        "zh": "NFT Maker"
      },
      "link": "/",
      "icon": "material-symbols:arrow-circle-up-outline",
      "section": [
        "header",
        "sessionManager",
        "dashboard"
      ],
      "role": [
        "admin",
        "owner"
      ]
    }
  ],
  "components": [
    {
      "name": "nft-store",
      "mountPoint": "/store",
      "source": {
        "name": "nft-store",
        "version": "latest",
        "store": "https://test.store.blocklet.dev"
      }
    },
    {
      "name": "nft-blender",
      "mountPoint": "/blender",
      "source": {
        "name": "nft-blender",
        "version": "latest",
        "store": "https://test.store.blocklet.dev"
      }
    }
  ],
