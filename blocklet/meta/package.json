{
  "name": "@blocklet/meta",
  "publishConfig": {
    "access": "public"
  },
  "version": "1.17.12",
  "description": "Library to parse/validate/fix blocklet meta",
  "homepage": "https://github.com/ArcBlock/blocklet-server/tree/main/blocklet/meta#readme",
  "main": "./lib/index.js",
  "typings": "./lib/index.d.ts",
  "files": [
    "lib"
  ],
  "scripts": {
    "verify": "npm run lint:fix && npm run coverage && npm run build",
    "lint": "eslint src tests",
    "lint:fix": "npm run lint -- --fix",
    "clean": "rm -fr lib",
    "types": "ts-node tools/types.js && sed -i.bak 's/unknown/string/g' ./src/types/schema.ts && rm  ./src/types/schema.ts.bak && prettier --write ./src/types/*.ts",
    "prebuild": "npm run clean && npm run types",
    "build:blocklet-meta": "npm run build",
    "build": "tsc"
  },
  "author": {
    "name": "ArcBlock",
    "email": "blocklet@arcblock.io",
    "url": "https://github.com/ArcBlock"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ArcBlock/blocklet-server.git",
    "directory": "blocklet/meta"
  },
  "bugs": {
    "url": "https://github.com/ArcBlock/blocklet-server/issues"
  },
