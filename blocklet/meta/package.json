    "cjk-length": "^1.0.0",
    "debug": "^4.4.1",
    "fs-extra": "^11.2.0",
    "hosted-git-info": "3.0.8",
    "hpagent": "^1.1.0",
    "is-absolute-url": "^3.0.3",
    "is-glob": "^4.0.3",
    "is-var-name": "^2.0.0",
