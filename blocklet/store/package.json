    "js-yaml": "^4.1.0",
    "json-stable-stringify": "^1.0.1",
    "lodash": "^4.17.21",
    "p-all": "^3.0.0",
    "p-wait-for": "^3.2.0",
    "tweetnacl": "^1.0.3",
