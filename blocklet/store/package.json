    "type": "git",
    "url": "https://github.com/ArcBlock/blocklet-server.git",
    "directory": "blocklet/store"
  },
  "bugs": {
    "url": "https://github.com/ArcBlock/blocklet-server/issues"
  },
  "homepage": "https://github.com/ArcBlock/blocklet-server/tree/main/blocklet/store#readme",
